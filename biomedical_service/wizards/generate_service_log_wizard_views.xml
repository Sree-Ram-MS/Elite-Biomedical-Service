<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_service_log_wizard_form" model="ir.ui.view">
        <field name="name">generate.service.log.wizard.form</field>
        <field name="model">generate.service.log.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Service Logs">
                <group>
                    <field name="sale_order_id" readonly="1" options="{'no_open': True}"/>
                    <field name="base_date"/>
                </group>
                <footer>
                    <button string="Generate" name="action_generate" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
