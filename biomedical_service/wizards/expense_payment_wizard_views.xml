<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biomedical_expense_payment_wizard_form" model="ir.ui.view">
        <field name="name">biomedical.expense.payment.wizard.form</field>
        <field name="model">biomedical.expense.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Expense Payment">
                <group>
                    <field name="expense_id" readonly="1" options="{'no_open': True}"/>
                    <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="payment_date"/>
                    <label for="amount"/>
                    <div class="o_row">
                        <field name="amount" readonly="1"/>
                        <field name="currency_id" readonly="1" options="{'no_open': True}"/>
                    </div>
                    <field name="communication"/>
                </group>
                <footer>
                    <button string="Register Payment" name="action_register" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
