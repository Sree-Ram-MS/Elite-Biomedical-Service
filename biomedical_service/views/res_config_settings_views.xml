<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Config Settings Form Inherit -->
    <record id="res_config_settings_view_form_inherit_biomedical" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.biomedical</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Biomedical Service" string="Biomedical Service" name="biomedical_service">
                    <block title="Service Reminders" name="biomedical_service_reminder_block">
                        <setting title="Service Reminders" help="Configure daily automated email and notification alerts for upcoming services.">
                            <field name="reminder_enabled"/>
                            <div invisible="not reminder_enabled" class="content-group mt16">
                                <div class="row mt16">
                                    <label for="reminder_days_before" class="col-lg-4 o_light_label" string="Remind Before (days)"/>
                                    <field name="reminder_days_before" class="oe_inline"/>
                                </div>
                                <div class="row mt16">
                                    <label for="reminder_user_ids" class="col-lg-4 o_light_label" string="Notify Users"/>
                                    <field name="reminder_user_ids" widget="many2many_tags" class="oe_inline" options="{'no_create': True}"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Settings Menu and Action -->
    <record id="action_biomedical_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'biomedical_service'}</field>
    </record>

    <menuitem id="menu_biomedical_settings" name="Settings" parent="menu_biomedical_root" action="action_biomedical_config_settings" sequence="100"/>
</odoo>
