<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Expense Type List View -->
    <record id="view_biomedical_expense_type_tree" model="ir.ui.view">
        <field name="name">biomedical.expense.type.list</field>
        <field name="model">biomedical.expense.type</field>
        <field name="arch" type="xml">
            <list string="Expense Types" editable="bottom">
                <field name="name"/>
                <field name="account_id"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Expense Type Form View -->
    <record id="view_biomedical_expense_type_form" model="ir.ui.view">
        <field name="name">biomedical.expense.type.form</field>
        <field name="model">biomedical.expense.type</field>
        <field name="arch" type="xml">
            <form string="Expense Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="account_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Expense Type Action -->
    <record id="action_biomedical_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Types</field>
        <field name="res_model">biomedical.expense.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Expense Type
            </p>
            <p>
                Expense types like Food, Petrol, etc. can be configured here, and linked to their default expense accounts.
            </p>
        </field>
    </record>
</odoo>
