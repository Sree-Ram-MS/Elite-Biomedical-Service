<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_biomedical_sale_expense_search" model="ir.ui.view">
        <field name="name">biomedical.sale.expense.search</field>
        <field name="model">biomedical.sale.expense</field>
        <field name="arch" type="xml">
            <search string="Search Expenses">
                <field name="sale_order_id"/>
                <field name="employee_id"/>
                <field name="expense_type_id"/>
                <field name="description"/>
                <filter string="Unpaid" name="unpaid" domain="[('payment_state', '=', 'unpaid')]"/>
                <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid')]"/>
                <group>
                    <filter string="Sale Order" name="group_by_sale_order" context="{'group_by': 'sale_order_id'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Expense Type" name="group_by_expense_type" context="{'group_by': 'expense_type_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'expense_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Sale Expense (List View Only) -->
    <record id="action_biomedical_sale_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">biomedical.sale.expense</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_group_by_sale_order': 1}</field>
        <field name="search_view_id" ref="view_biomedical_sale_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new sale expense
            </p>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_biomedical_sale_expense_form" model="ir.ui.view">
        <field name="name">biomedical.sale.expense.form</field>
        <field name="model">biomedical.sale.expense</field>
        <field name="arch" type="xml">
            <form string="Sale Expense">
                <header>
                    <button name="action_register_payment" string="Register Payment" type="object" class="btn-primary" invisible="payment_state == 'paid'"/>
                    <button name="action_view_payment" string="View Payment" type="object" class="btn-secondary" invisible="payment_state != 'paid'"/>
                    <field name="payment_state" widget="statusbar" statusbar_visible="unpaid,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="sale_order_id"/>
                            <field name="expense_date"/>
                            <field name="expense_type_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <label for="amount"/>
                            <div class="o_row">
                                <field name="amount"/>
                                <field name="currency_id" options="{'no_open': True, 'no_create': True}"/>
                            </div>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="payment_id" invisible="not payment_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional details..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_biomedical_sale_expense_list" model="ir.ui.view">
        <field name="name">biomedical.sale.expense.list</field>
        <field name="model">biomedical.sale.expense</field>
        <field name="arch" type="xml">
            <list string="Sale Expenses" editable="bottom">
                <field name="expense_date"/>
                <field name="expense_type_id"/>
                <field name="description"/>
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="payment_state" widget="badge" decoration-success="payment_state == 'paid'" decoration-danger="payment_state == 'unpaid'"/>
                <field name="user_id" string="Logged By" readonly="1"/>
                <field name="sale_order_id" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
                <button name="action_register_payment" string="Register Payment" type="object" class="btn-secondary" icon="fa-money" invisible="payment_state == 'paid'"/>
                <button name="action_view_payment" string="View Payment" type="object" class="btn-secondary" icon="fa-eye" invisible="payment_state != 'paid'"/>
            </list>
        </field>
    </record>

    <!-- Expense Type Action -->
    <record id="action_biomedical_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Types</field>
        <field name="res_model">biomedical.expense.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define a new expense type
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_biomedical_sale_expense" 
              name="Expenses" 
              parent="menu_biomedical_root" 
              action="action_biomedical_sale_expense" 
              sequence="20"/>

    <menuitem id="menu_biomedical_expense_type" 
              name="Expense Types" 
              parent="menu_biomedical_settings" 
              action="action_biomedical_expense_type" 
              sequence="10"/>
</odoo>
