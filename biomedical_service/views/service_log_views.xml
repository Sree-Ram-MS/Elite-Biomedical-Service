<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_biomedical_service_log_search" model="ir.ui.view">
        <field name="name">biomedical.service.log.search</field>
        <field name="model">biomedical.service.log</field>
        <field name="arch" type="xml">
            <search string="Search Service Logs">
                <field name="name" string="Log Ref"/>
                <field name="sale_order_id" string="Sale Order"/>
                <field name="service_name" string="Service Name"/>
                <field name="employee_id" string="Employee"/>
                <!-- State filters -->
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <!-- Overdue filter -->
                <filter string="Overdue" name="overdue" domain="[('scheduled_date', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', '=', 'draft')]"/>
                <group>
                    <filter string="Sale Order" name="group_by_sale_order" context="{'group_by': 'sale_order_id'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Scheduled Date" name="group_by_scheduled_date" context="{'group_by': 'scheduled_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Service Logs -->
    <record id="action_biomedical_service_log" model="ir.actions.act_window">
        <field name="name">Service Logs</field>
        <field name="res_model">biomedical.service.log</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_group_by_sale_order': 1}</field>
        <field name="search_view_id" ref="view_biomedical_service_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage service logs and upcoming maintenance tasks.
            </p>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_biomedical_service_log_form" model="ir.ui.view">
        <field name="name">biomedical.service.log.form</field>
        <field name="model">biomedical.service.log</field>
        <field name="arch" type="xml">
            <form string="Service Log">
                <header>
                    <button name="action_complete" string="Complete Service" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object" class="btn-primary" invisible="invoice_id or state != 'completed'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="btn-secondary" invisible="state != 'completed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sale_order_id" readonly="state == 'completed'"/>
                            <field name="service_config_id" invisible="1"/>
                            <field name="service_name" readonly="state == 'completed'"/>
                            <field name="employee_id" readonly="state == 'completed'"/>
                            <field name="invoice_id" readonly="1" options="{'no_open': False}"/>
                        </group>
                        <group>
                            <field name="scheduled_date" readonly="state == 'completed'"/>
                            <field name="completed_date" readonly="state == 'completed'"/>
                            <field name="current_used_hours" readonly="state == 'completed'"/>
                            <field name="interval_hours" readonly="state == 'completed'"/>
                            <field name="reminder_sent" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service Lines" name="service_lines">
                            <field name="service_line_ids" readonly="state == 'completed'">
                                <list string="Service Lines" editable="bottom">
                                    <field name="product_id" string="Product / Equipment"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" sum="Total Amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Service report, parts replaced, or technician notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_biomedical_service_log_list" model="ir.ui.view">
        <field name="name">biomedical.service.log.list</field>
        <field name="model">biomedical.service.log</field>
        <field name="arch" type="xml">
            <list string="Service Logs" decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="service_name"/>
                <field name="scheduled_date"/>
                <field name="completed_date"/>
                <field name="employee_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_biomedical_service_log_kanban" model="ir.ui.view">
        <field name="name">biomedical.service.log.kanban</field>
        <field name="model">biomedical.service.log</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="service_name"/>
                <field name="scheduled_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="text-muted"><field name="service_name"/></span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Date: <field name="scheduled_date"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'completed': 'success'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_biomedical_root" name="Biomedical Service" web_icon="biomedical_service,static/description/icon.png" sequence="25"/>
    <menuitem id="menu_biomedical_service_log" name="Service Logs" parent="menu_biomedical_root" action="action_biomedical_service_log" sequence="10"/>
</odoo>
