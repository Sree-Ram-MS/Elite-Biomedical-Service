<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_openwa_connection_wizard_form" model="ir.ui.view">
        <field name="name">openwa.connection.wizard.form</field>
        <field name="model">openwa.connection.wizard</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Connection Setup">
                <sheet>
                    <div class="alert alert-info text-center" role="alert" style="margin-bottom: 20px;">
                        <h3>Pairing Session: <field name="session_name" readonly="1"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="status" string="Current Status" readonly="1" class="text-capitalize fw-bold"/>
                        </group>
                    </group>
                    <div style="margin: 15px 0;">
                        <p class="text-muted"><field name="message" readonly="1"/></p>
                    </div>
                    <div class="row justify-content-center">
                        <div class="col-12 text-center">
                            <field name="qr_code_html" readonly="1"/>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Refresh" name="action_refresh" type="object" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
